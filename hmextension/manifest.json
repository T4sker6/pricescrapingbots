{
  "manifest_version": 3,
  "name": "HM Price Tracker",
  "version": "1.0",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www2.hm.com/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HM Price Tracker"
  }
}
